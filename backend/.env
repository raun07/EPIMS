# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=EPIMS
APP_ENV=development
DEBUG=false

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=epims
POSTGRES_PASSWORD=epims_dev_password
POSTGRES_DB=epims

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1

# ── Object Storage (MinIO) ────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=epims-documents

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── AI Copilot ────────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model selection (defaults are cost-optimised — change only if needed)
# AI_MODEL_PRIMARY=claude-sonnet-4-6
# AI_MODEL_FAST=claude-haiku-4-5-20251001
# AI_MODEL_VISION=claude-sonnet-4-6

# Feature flag — set False to disable AI without removing code
AI_ENABLED=false

# Cost guard: reject requests estimated to cost more than this (USD)
AI_MAX_COST_PER_REQUEST_USD=0.50

# Analytics safety
AI_ANALYTICS_MAX_ROWS=1000
AI_ANALYTICS_TIMEOUT_SECS=5

# Cache TTLs
AI_VENDOR_REC_CACHE_TTL_HOURS=24
AI_POLICY_CACHE_TTL_HOURS=1

# ── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=

# ── First Superuser ───────────────────────────────────────────────────────────
FIRST_SUPERUSER_EMAIL=admin@epims.com
FIRST_SUPERUSER_PASSWORD=Admin@123456
FIRST_SUPERUSER_NAME=System Administrator
EMAIL_FROM=noreply@gmail.com
